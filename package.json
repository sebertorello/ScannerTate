{
  "name": "scannertate",
  "version": "1.0.0",
  "description": "Escáner QR/barras desde celular hacia PC",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "icons": "node scripts/build-icons.js",
    "dist:mac": "npm run icons && electron-builder --mac",
    "dist:win": "npm run icons && electron-builder --win",
    "dist": "npm run icons && electron-builder -mw"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "qrcode": "^1.5.4",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.verticalproducciones.scannertate",
    "productName": "ScannerTate",
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
